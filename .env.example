# Bybit API - Mainnet (required for Live Trading only)
# Get keys from: https://www.bybit.com/app/user/api-management
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Bybit API - Testnet (for E2E testing)
# Get keys from: https://testnet.bybit.com/app/user/api-management
BYBIT_TESTNET_API_KEY=
BYBIT_TESTNET_API_SECRET=

# Discord Webhook (optional, for notifications)
# Create at: Server Settings -> Integrations -> Webhooks
DISCORD_WEBHOOK_URL=

# Telegram Bot (optional, for notifications)
# Create bot: @BotFather, get chat_id: @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
